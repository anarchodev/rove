# node.env — GENESIS profile, PER-HOST. Install to ~/.config/rove/node.env on
# each host with that host's 1-based id and its own raft listen address.
#
# Vs the rolling node.env: this adds REWIND_RAFT_ADDR — the worker's OWN raft
# transport host:port. In rolling mode the worker derives its listen address
# positionally from REWIND_PEERS[id-1]; in genesis mode REWIND_PEERS is absent,
# so each node must state its own address here. (REWIND_RAFT_ADDR is read ONLY
# when REWIND_VOTERS/REWIND_PEERS are unset — i.e. it is inert in rolling mode,
# so it is safe to leave set across a later switch to rolling.)
#
# The CP directory group stays cold-multi static, so REWIND_CP_NODE_ID still
# indexes REWIND_CP_PEERS in common.env to pick this node's CP raft address.
#
# ── host-1 (10.0.0.1) ──
REWIND_NODE_ID=1
REWIND_CP_NODE_ID=1
REWIND_RAFT_ADDR=10.0.0.1:8501

# host-2 (10.0.0.2) would be:
#   REWIND_NODE_ID=2
#   REWIND_CP_NODE_ID=2
#   REWIND_RAFT_ADDR=10.0.0.2:8501
# host-3 (10.0.0.3):
#   REWIND_NODE_ID=3
#   REWIND_CP_NODE_ID=3
#   REWIND_RAFT_ADDR=10.0.0.3:8501
