# common.env — deploy-wide config, IDENTICAL on all 3 nodes.
# Install to ~/.config/rove/common.env (chmod 0600 — holds secrets).
# Read by rewind-cp / rewind / rewind-front (each picks the vars it needs;
# extra vars are harmless). NOTE: this file is plain KEY=VALUE — systemd
# does NOT expand %h or shell syntax here. Use absolute values.
#
# Per-node values (node id) live in node.env, NOT here.
# Verified env contract: docs/v2-production-deploy-plan.md §2 + §10.

# ─── Blob / object storage (REQUIRED — binaries hard-error if unset) ───
S3_ENDPOINT=https://s3.gra.io.cloud.ovh.net
S3_REGION=gra
S3_BUCKET=rewind-prod
S3_KEY_PREFIX_BASE=prod/
S3_USE_TLS=1
AWS_ACCESS_KEY_ID=CHANGE_ME
AWS_SECRET_ACCESS_KEY=CHANGE_ME

# ─── Secrets (MUST set strong random values before exposing anything) ──
# REWIND_MOVE_SECRET gates ALL /_control + /_system/v2-* calls.
# REWIND_ROOT_TOKEN is the /_system/admin-kv bearer — the worker REFUSES
# TO BOOT if it is unset, empty, or equal to the compiled-in default, so
# set a strong unique value here. (docs §2.5 / §10)
REWIND_MOVE_SECRET=CHANGE_ME_64_hex_chars
REWIND_ROOT_TOKEN=CHANGE_ME_64_hex_chars

# ─── Domains / suffixes (the auth-domain isolation boundary) ───────────
REWIND_PUBLIC_SUFFIX=rewindjs.app
REWIND_SYSTEM_SUFFIX=rewindjs.com
REWIND_ADMIN_DOMAIN=app.rewindjs.com

# ─── Tenant door (inter-tenant fetch fast path; deploy plan §2.1) ──────
# Comma-sep bare PRIVATE-plane (vRack) IPs of the fronts: outbound fetches
# to our own platform hostnames pin their connect here instead of
# resolving public DNS. Unset = inert (those fetches take the public edge).
REWIND_INTERNAL_FRONT=10.0.0.1,10.0.0.2,10.0.0.3

# ─── DP (worker) cluster topology — same on every node ─────────────────
# Voter ids and the raft peer transport (host:port), index = node_id-1.
# These are PRIVATE-NETWORK addresses; :8501 must be firewalled to the 3.
REWIND_VOTERS=1,2,3
REWIND_PEERS=10.0.0.1:8501,10.0.0.2:8501,10.0.0.3:8501
# This DP cluster's id; must match a key in REWIND_CLUSTERS below. Set
# together with REWIND_CP_URL or a local-tenant miss 404s (no forward).
REWIND_CLUSTER_ID=prod
# CP origins (HA): the worker + front resolve placement here. ';'-list.
REWIND_CP_URL=http://10.0.0.1:9090;http://10.0.0.2:9090;http://10.0.0.3:9090

# ─── CP (directory) cluster topology — same on every node ──────────────
REWIND_CP_VOTERS=1,2,3
REWIND_CP_PEERS=10.0.0.1:9101,10.0.0.2:9101,10.0.0.3:9101
REWIND_CP_PEER_URLS=http://10.0.0.1:9090,http://10.0.0.2:9090,http://10.0.0.3:9090
REWIND_CP_RECONCILE_SECS=30

# ─── CP directory seed (leader seeds once; durable after) ──────────────
# cluster id -> the worker h2c origins the front proxies to (:8443).
REWIND_CLUSTERS=prod=http://10.0.0.1:8443,http://10.0.0.2:8443,http://10.0.0.3:8443
# tenant=cluster ; and host=tenant. Empty at first; grows at runtime via
# /_control/provision + /_control/host. Seed system hosts here if desired.
REWIND_PLACEMENT=
REWIND_HOSTS=

# ─── ACME (set REWIND_ACME_DIRECTORY to enable the CP HTTP-01 issuer) ──
# Inert unless set. For launch you may instead seed one manual wildcard
# cert (docs §4 bootstrap). Use the staging dir first to avoid rate limits.
REWIND_ACME_DIRECTORY=https://acme-v02.api.letsencrypt.org/directory
REWIND_ACME_CONTACT=mailto:ops@rewindjs.com

# ─── Raft tuning ───────────────────────────────────────────────────────
# Raft logical-tick cadence (ms), read by rewind (tenant groups) + rewind-cp
# (directory group). The wall-clock election timeout ≈ election_tick(10) × this,
# so 10ms ⇒ ~100-300ms election / ~30ms heartbeat — the etcd / Raft-paper band.
# The compiled default (1ms) gives a ~15-20ms election timeout: fine on a tight
# sub-ms LAN but in the aggressive regime (tighter than any mainstream default
# on both the absolute value and the heartbeat ratio). 10ms costs no measured
# throughput (soak: scripts/raft_soak_v2.py) and buys margin against the
# pump/fsync/scheduler pause tail. Re-soak for hours on THIS hardware before
# treating it as final. See docs/raft-best-practices.md "how to size".
REWIND_RAFT_TICK_MS=10

# ─── Front tuning ──────────────────────────────────────────────────────
REWIND_HTTP_PORT=80
REWIND_ROUTE_CACHE_MS=1000
REWIND_CERT_SYNC_MS=5000

# ─── Operator metrics (Prometheus text over loopback HTTP/1.1) ──────────
# Each binary serves /metrics on a dedicated 127.0.0.1 port, isolated from
# tenant traffic and answerable while the main request path is wedged (the
# node-local Grafana Alloy scrapes it; loopback IS the auth). 0 disables.
# Worker (raft_groups{,_no_leader}, raftnet_peers_unreachable — the wedge
# signals) and CP (the same directory-group gauges + cp_reconcile_* counters)
# use distinct defaults so both coexist on one host.
REWIND_METRICS_PORT=9110
REWIND_CP_METRICS_PORT=9111
