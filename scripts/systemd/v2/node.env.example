# node.env — PER-HOST config. The ONLY values that differ between the 3
# nodes. Install to ~/.config/rove/node.env on each host with that host's
# 1-based id (host-1 → 1, host-2 → 2, host-3 → 3).
#
# The id indexes REWIND_PEERS / REWIND_CP_PEERS in common.env to pick
# this node's raft listen address. The worker raft id and CP raft id are
# kept equal per host by convention (separate raft clusters, aligned ids).
#
# ── host-1 ──
REWIND_NODE_ID=1
REWIND_CP_NODE_ID=1

# host-2 would be:
#   REWIND_NODE_ID=2
#   REWIND_CP_NODE_ID=2
# host-3:
#   REWIND_NODE_ID=3
#   REWIND_CP_NODE_ID=3
