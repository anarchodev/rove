# common.env — GENESIS profile (cold bring-up of a virgin / torn-down cluster).
# Install to ~/.config/rove/common.env (chmod 0600 — holds secrets) on ALL 3
# nodes for a from-empty bring-up, THEN run `rewind-ops genesis`.
#
# Differences from the ROLLING profile (common.env.example) — and ONLY these:
#   * Workers boot SELF-ONLY: REWIND_VOTERS / REWIND_PEERS are ABSENT here, and
#     each node sets its own REWIND_RAFT_ADDR in node.env. A worker tenant group
#     is then born as the sole voter {1} on node 1 and GROWN to {1,2,3} by the CP
#     reconciler (bootstrap-1-grow). Tenant-group membership lives in the raft
#     WAL (ConfState), so this profile is also steady-state-safe across restarts —
#     you do NOT have to switch back to the rolling profile after the grow.
#   * The CP runs the membership reconciler: REWIND_CP_RECONCILE_MEMBERSHIP=1.
#   * The CP directory group itself stays COLD-MULTI static (REWIND_CP_VOTERS /
#     _PEERS / _PEER_URLS, same as rolling) — a born-{1,2,3} directory group that
#     elects on its own (validated: scripts/cp_genesis_3node.py).
#
# WHY a separate file (not a comment-toggle): leaving REWIND_VOTERS/PEERS set by
# accident silently reverts workers to the cold-multi path, which does NOT form
# tenant groups from empty. Copy THIS file for a genesis bring-up; copy
# common.env.example for a rolling upgrade of an already-running cluster.
#
# systemd does NOT expand %h or shell syntax here — use absolute values.
# Per-node values (node id + this node's raft addr) live in node.env.

# ─── Blob / object storage (REQUIRED — binaries hard-error if unset) ───
S3_ENDPOINT=https://s3.gra.io.cloud.ovh.net
S3_REGION=gra
S3_BUCKET=rewind-prod
S3_KEY_PREFIX_BASE=prod/
S3_USE_TLS=1
AWS_ACCESS_KEY_ID=CHANGE_ME
AWS_SECRET_ACCESS_KEY=CHANGE_ME

# ─── Secrets (MUST set strong random values before exposing anything) ──
# REWIND_MOVE_SECRET gates ALL /_control + /_system/v2-* calls (and is REQUIRED
# when REWIND_CP_RECONCILE_MEMBERSHIP=1). REWIND_ROOT_TOKEN is the admin-kv
# bearer — the worker REFUSES TO BOOT if it is unset/empty/the compiled default.
REWIND_MOVE_SECRET=CHANGE_ME_64_hex_chars
REWIND_ROOT_TOKEN=CHANGE_ME_64_hex_chars

# ─── Domains / suffixes (the auth-domain isolation boundary) ───────────
REWIND_PUBLIC_SUFFIX=rewindjs.app
REWIND_SYSTEM_SUFFIX=rewindjs.com
REWIND_ADMIN_DOMAIN=app.rewindjs.com

# ─── Tenant door (inter-tenant fetch fast path) ────────────────────────
REWIND_INTERNAL_FRONT=10.0.0.1,10.0.0.2,10.0.0.3

# ─── DP (worker) cluster — GENESIS: NO static voter/peer set ────────────
# REWIND_VOTERS / REWIND_PEERS are DELIBERATELY ABSENT (that is what selects
# self-only genesis boot). Each node's own raft listen address is REWIND_RAFT_ADDR
# in node.env. Peer raft addresses are learned from the CP node-address registry
# (seeded by `rewind-ops genesis` / `node-addr`), so they are NOT static here.
#
# REWIND_PEER_URLS — positional (id-1) worker HTTP origins, the out-of-band
# snapshot-catch-up push target seed. Same on every node. (The registry's
# http_url is authoritative; this is a seed so a far-behind joiner can be caught
# up even before its address row commits.)
REWIND_PEER_URLS=http://10.0.0.1:8443,http://10.0.0.2:8443,http://10.0.0.3:8443
# This DP cluster's id; must match a key in REWIND_CLUSTERS below.
REWIND_CLUSTER_ID=prod
# CP origins (HA): the worker + front resolve placement here. ';'-list.
REWIND_CP_URL=http://10.0.0.1:9090;http://10.0.0.2:9090;http://10.0.0.3:9090

# ─── CP (directory) cluster — cold-multi static (same as rolling) ──────
REWIND_CP_VOTERS=1,2,3
REWIND_CP_PEERS=10.0.0.1:9101,10.0.0.2:9101,10.0.0.3:9101
REWIND_CP_PEER_URLS=http://10.0.0.1:9090,http://10.0.0.2:9090,http://10.0.0.3:9090
REWIND_CP_RECONCILE_SECS=30
# GENESIS: enable the membership reconciler — it grows each born-{1} tenant group
# to the full node set learner-first. REQUIRES REWIND_MOVE_SECRET (set above).
REWIND_CP_RECONCILE_MEMBERSHIP=1

# ─── CP directory seed (leader seeds once; durable after) ──────────────
# cluster id -> the worker h2c origins the front proxies to (:8443).
REWIND_CLUSTERS=prod=http://10.0.0.1:8443,http://10.0.0.2:8443,http://10.0.0.3:8443
REWIND_PLACEMENT=
REWIND_HOSTS=

# ─── ACME (set REWIND_ACME_DIRECTORY to enable the CP HTTP-01 issuer) ──
REWIND_ACME_DIRECTORY=https://acme-v02.api.letsencrypt.org/directory
REWIND_ACME_CONTACT=mailto:ops@rewindjs.com

# ─── Raft tuning (identical to rolling — keep CP + worker in lockstep) ──
REWIND_RAFT_TICK_MS=10

# ─── Front tuning ──────────────────────────────────────────────────────
REWIND_HTTP_PORT=80
REWIND_ROUTE_CACHE_MS=1000
REWIND_CERT_SYNC_MS=5000
