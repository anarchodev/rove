# deploy.conf — config for scripts/deploy.sh. Copy to
# ~/.config/rove/deploy.conf (preferred — survives worktree churn) or the
# legacy scripts/deploy.conf, and edit. deploy.sh ships ONLY binaries +
# restarts; it never pushes env files / secrets (provisioned out-of-band).

# SSH targets to DEPLOY, space-separated. One at a time, in order. Order
# is not safety-critical (one host fully restarts + rejoins quorum before
# the next; CP re-elects sub-second and clients retry the CP list), but
# listing a known follower first is a nice-to-have.
ROVE_HOSTS="rove@host-1 rove@host-2 rove@host-3"

# SSH targets of EVERY CP (directory-raft) member — used only by the
# leader-readiness probe between restarts. Defaults to ROVE_HOSTS. Set it
# explicitly when the cluster has members you are NOT deploying (e.g. a
# node held back on an older build): the directory leader may live on one
# of those, and a follower's 503 gives no leader hint, so the probe must
# be able to reach the leader's node or it false-negatives "no leader".
# ROVE_CLUSTER_HOSTS="rove@host-1 rove@host-2 rove@host-3 rove@host-4"

# Remote bin dir, relative to the SSH user's home.
ROVE_BIN_DIR=".local/bin"

# Seconds to let a just-restarted node settle (raft rejoin/catch-up)
# before touching the next host. Conservative; keeps quorum safe.
ROVE_SETTLE_SECS=10

# Set to 1 if you bind :443/:80 via setcap (must be re-applied after each
# binary replace). Leave 0 if you used the sysctl approach (recommended).
# ROVE_SETCAP=1 requires passwordless sudo for setcap on each host.
ROVE_SETCAP=0

# Set to 1 to skip the local build's test gate (NOT recommended).
ROVE_SKIP_TESTS=0

# ssh / rsync commands (override for jump hosts, keys, etc.)
ROVE_SSH="ssh"
ROVE_RSYNC="rsync"

# ─── GENESIS mode (scripts/deploy.sh --genesis) ───────────────────────
# Only needed for a clean-slate cold bring-up of a VIRGIN/wiped cluster.
# Rolling (the default) ignores everything below.
#
# Path to the rewind-ops --env file driving the operator-side bring-up
# (register node addrs → provision __admin__ born {1,2,3} cold-multi → reset).
# It must define: ROVE_CP_URL_INTERNAL, ROVE_WORKER_URLS, REWIND_MOVE_SECRET,
# REWIND_ROOT_TOKEN, REWIND_ADMIN_DOMAIN, ROVE_CLUSTER, and ROVE_GENESIS_NODES
# ("id=worker_raft_addr[,cp_raft_addr[,worker_http_url]];…" per node). Commonly
# your prod.env with ROVE_GENESIS_NODES appended. The CP/worker URLs in it must
# be reachable from where you run deploy.sh (vRack VPN, or run from a node).
# PRECONDITION: the nodes' active EnvironmentFile is the cold-multi profile
# (scripts/systemd/v2/{common,node}.env.example — workers REWIND_VOTERS/REWIND_PEERS
# set, CP cold-multi, reconciler OFF) — the SAME profile rolling uses.
# NOTE: --genesis WIPES ~/.rove/data on all hosts (guarded by the leader refusal).
# ROVE_GENESIS_ENV="$HOME/.config/rove/prod.genesis.env"

# Seconds to wait for the cold-multi directory group to elect after the CPs are
# started together (cross-host election is ~1-2s; default 60 is generous).
# ROVE_CP_ELECT_TIMEOUT=60

# Set to 1 to genesis even when a directory leader already exists. ONLY after a
# deliberate data wipe — genesis on a formed cluster split-brains it.
# ROVE_GENESIS_FORCE=0
