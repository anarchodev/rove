            }
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "last",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi"
        }
      }
    },
    {
      "type": "row",
      "title": "Control plane (CP reconciler)",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 28
      },
      "id": 17,
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "reconcile passes /min",
      "description": "Reconciler liveness. ~0 in cold-multi (reconciler off); non-zero only for deliberate DR ops.",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 7,
        "w": 12,
        "x": 0,
        "y": 29
      },
      "id": 18,
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "sum by (instance) (rate(cp_reconcile_passes_total[5m]) * 60)",
          "refId": "A",
          "editorMode": "code",
          "range": true,
          "legendFormat": "{{instance}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "fillOpacity": 8,
            "showPoints": "never",
