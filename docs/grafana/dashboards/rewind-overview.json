      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 20
      },
      "id": 13,
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "raft groups (total vs led)",
      "description": "Worker tenant groups per node (born fully replicated) and how many each leads.",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 7,
        "w": 8,
        "x": 0,
        "y": 21
      },
      "id": 14,
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "sum by (instance) (raft_groups{job=\"rewind-worker\"})",
          "refId": "A",
          "editorMode": "code",
          "range": true,
          "legendFormat": "groups {{instance}}"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "sum by (instance) (raft_groups_led{job=\"rewind-worker\"})",
          "refId": "B",
          "editorMode": "code",
          "range": true,
          "legendFormat": "led {{instance}}"
