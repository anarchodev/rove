        }
      }
    },
    {
      "type": "timeseries",
      "title": "leadership acquisitions /min (spurious-election signal)",
      "description": "follower\u2192leader edges. ~flat at steady state; rising = election timeout too tight.",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 7,
        "w": 8,
        "x": 8,
        "y": 21
      },
      "id": 15,
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "sum by (instance) (rate(raft_leadership_acquisitions_total[5m]) * 60)",
          "refId": "A",
          "editorMode": "code",
          "range": true,
          "legendFormat": "{{instance}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "fillOpacity": 8,
            "showPoints": "never",
            "stacking": {
              "mode": "none"
            }
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "last",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi"
        }
      }
    },
    {
      "type": "timeseries",
      "title": "heartbeat RTT (mean, \u00b5s)",
      "description": "Broadcast time; the election timeout must sit well above this.",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 7,
        "w": 8,
        "x": 16,
        "y": 21
      },
      "id": 16,
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "sum by (instance) (rate(raft_heartbeat_rtt_us_sum[5m])) / clamp_min(sum by (instance) (rate(raft_heartbeat_rtt_us_count[5m])), 1)",
          "refId": "A",
          "editorMode": "code",
          "range": true,
          "legendFormat": "{{instance}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "\u00b5s",
          "custom": {
            "fillOpacity": 8,
            "showPoints": "never",
            "stacking": {
